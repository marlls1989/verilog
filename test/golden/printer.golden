output y;
endmodule
primitive p_udp(Q, A, B);
output Q;
input  A, B;
reg    Q;
table
	0 ? : ? : 0;
	1 1 : ? : 1;
endtable
endprimitive
`celldefine
module the_cell(Q, A);
output Q;
input  A;
specify
	(A => Q) = (0.1, 0.1);
endspecify
endmodule
